<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab id="TabAddIns" label="Notes Tools">
		<group id="NotesGroup"
				label="Search Notes">
			<button id="searchButton"
					getImage="notesSearchButton_GetImage"
					label="Search Notes"
					onAction="OnSearchNotes"
					screentip="Search Notes"
					size="large"
					supertip="Search for keywords within notes" />
			<button id="setupButton"
					getImage="notesConfigButton_GetImage"
					label="Setup Config"
					onAction="OnSearchConfig"
					screentip="Configure Search"
					size="large"
					supertip="Configure search of notes" />
			<button id="mergeNotesButton"
					getImage="mergeNotesButton_GetImage"
					label="Merge Notes"
					onAction="OnMergeNotes"
					screentip="Merge notes"
					size="large"
					supertip="Merge results on index" />
			<button id="extractMessageButton"
					getImage="extractMessageButton_GetImage"
					label="Extract Message"
					onAction="OnExtractMessage"
					screentip="Extract Msg to Pt"
					size="large"
					supertip="Extract Message to Patient" />
		</group>
	  </tab>
    </tabs>
  </ribbon>
</customUI>

